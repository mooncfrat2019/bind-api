# Роль сервера
APP_ROLE=replica

# BIND настройки
BIND_ZONE_DIR=/var/named/
BIND_NAMED_CONF=/etc/named.conf
BIND_ZONE_CONF=/etc/named.zones.conf

# API настройки
API_PORT=:9002
GIN_MODE=release

# Синхронизация (REPLICA)
MASTER_URL=http://100.10.10.3:8080
MASTER_API_TOKEN=secret
SYNC_INTERVAL=30
SYNC_ENABLED=true

# === ТРАНСФОРМАЦИИ КОНФИГУРАЦИИ ===

# IP адрес мастера для директивы masters {}
REPLICA_MASTER_IP=100.10.10.3

# Тип зон на реплике (master/slave/hint)
REPLICA_ZONE_TYPE=slave

# Подкаталог для файлов зон на реплике (опционально)
REPLICA_ZONE_SUBDIR=slaves

# Заменить allow-transfer на реплике (опционально)
REPLICA_REMOVE_ALLOW_TRANSFER=true

# Заменить allow-transfer на свой (если нужны свои слейвы)
# REPLICA_ALLOW_TRANSFER=10.69.13.5; 10.69.13.6;


# === ТРАНСФОРМАЦИИ (структурированные флаги) ===
REPLICA_MASTER_IP=100.69.13.3
REPLICA_ZONE_TYPE=slave
REPLICA_ZONE_SUBDIR=slaves
REPLICA_REMOVE_ALLOW_TRANSFER=true
REPLICA_DISABLE_IPV6=true

