# PostgreSQL
BIND_API_DB_HOST=localhost
BIND_API_DB_PORT=5432
BIND_API_DB_USER=bindapi
BIND_API_DB_PASSWORD=your_secure_password
BIND_API_DB_NAME=bind_api
BIND_API_DB_SSLMODE=disable

# Временный bootstrap API-ключ.
# Используется только если таблица api_keys пуста.
# Ключ создаётся с правами "*" и сроком действия 7 дней.
# После первого входа создайте постоянный ключ через API и отзовите bootstrap-ключ.
BIND_API_BOOTSTRAP_KEY=

# Или через connection string
BIND_API_DB_URL=postgres://bindapi:your_secure_password@localhost:5432/bind_api?sslmode=disable

# Остальные настройки
BIND_ZONE_DIR=/var/named/
BIND_NAMED_CONF=/etc/named.conf
API_PORT=:8080

MAX_QUEUE_SIZE=1000
WORKER_TIMEOUT=180
BATCH_SIZE=50
BATCH_INTERVAL=5
QUEUE_THRESHOLD_LOW=0.1
QUEUE_THRESHOLD_HIGH=0.3
RELOAD_INTERVAL=10

SYNC_CLEANUP_INTERVAL=5m